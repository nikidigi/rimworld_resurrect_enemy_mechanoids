<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Friendly Mechanoids -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/RecipeDef[defName="ResurrectMediumMech"]/fixedIngredientFilter/thingDefs</xpath>
    <value>
      <li>Corpse_Mech_Termite</li>
      <li>Corpse_Mech_Apocriton</li>
    </value>
  </Operation>

  <!-- Hostile Mechanoids -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs</xpath>
    <value>
      <RecipeDef ParentName="BaseHostileMechanoidRecipe">
        <defName>ResurrectHostileMediumMech</defName>
        <label>resurrect hostile medium mechanoid</label>
        <description>Resurrect a hostile medium mechanoid. Its core must be reinitialized to accept new directives. Requires a standard subcore for reprogramming.</description>
        <ingredients>
          <li>
            <filter>
              <categories>
                <li>Corpses</li>
              </categories>
            </filter>
            <count>1</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>Steel</li>
              </thingDefs>
            </filter>
            <count>50</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>SubcoreRegular</li>
              </thingDefs>
            </filter>
            <count>1</count>
          </li>
        </ingredients>
        <fixedIngredientFilter>
          <thingDefs>
            <li>Corpse_Mech_Lancer</li>
            <li>Corpse_Mech_Pikeman</li>
            <li>Corpse_Mech_Scorcher</li>
            <li>Corpse_Mech_Scyther</li>
            <li>Corpse_Mech_Termite</li>
            <li>Corpse_Mech_Tunneler</li>
            <li MayRequire="Ludeon.RimWorld.Odyssey">Corpse_Mech_Cyclops</li>
          </thingDefs>
        </fixedIngredientFilter>
        <researchPrerequisite>StandardMechtech</researchPrerequisite>
      </RecipeDef>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs</xpath>
    <value>
      <RecipeDef ParentName="BaseHostileMechanoidRecipe">
        <defName>ResurrectHostileAdvancedMech</defName>
        <label>resurrect hostile medium mechanoid (high)</label>
        <description>Resurrect a hostile medium mechanoid. Its core must be reinitialized to accept new directives. Requires a high subcore for reprogramming.</description>
        <ingredients>
          <li>
            <filter>
              <categories>
                <li>Corpses</li>
              </categories>
            </filter>
            <count>1</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>Steel</li>
              </thingDefs>
            </filter>
            <count>50</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>SubcoreHigh</li>
              </thingDefs>
            </filter>
            <count>1</count>
          </li>
        </ingredients>
        <fixedIngredientFilter>
          <thingDefs>
            <li>Corpse_Mech_Legionary</li>
            <li>Corpse_Mech_Tesseron</li>
          </thingDefs>
        </fixedIngredientFilter>
        <researchPrerequisite>HighMechtech</researchPrerequisite>
      </RecipeDef>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs</xpath>
    <value>
      <RecipeDef ParentName="BaseHostileMechanoidRecipe">
        <defName>ResurrectHostileHeavyMech</defName>
        <label>resurrect hostile heavy mechanoid</label>
        <description>Resurrect a hostile heavy mechanoid. Its core must be reinitialized to accept new directives. Requires a high subcore for reprogramming.</description>
        <ingredients>
          <li>
            <filter>
              <categories>
                <li>Corpses</li>
              </categories>
            </filter>
            <count>1</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>Steel</li>
              </thingDefs>
            </filter>
            <count>100</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>SubcoreHigh</li>
              </thingDefs>
            </filter>
            <count>1</count>
          </li>
        </ingredients>
        <fixedIngredientFilter>
          <thingDefs>
            <li>Corpse_Mech_CentipedeBlaster</li>
            <li>Corpse_Mech_CentipedeBurner</li>
            <li>Corpse_Mech_CentipedeGunner</li>
          </thingDefs>
        </fixedIngredientFilter>
        <researchPrerequisite>HighMechtech</researchPrerequisite>
      </RecipeDef>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs</xpath>
    <value>
      <RecipeDef ParentName="BaseHostileMechanoidRecipe">
        <defName>ResurrectHostileUltraHeavyMech</defName>
        <label>resurrect hostile ultraheavy mechanoid</label>
        <description>Resurrect a hostile ultraheavy mechanoid. Its core must be fully reinitialized to accept new directives. Advanced systems require additional components and a high subcore.</description>
        <ingredients>
          <li>
            <filter>
              <categories>
                <li>Corpses</li>
              </categories>
            </filter>
            <count>1</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>Steel</li>
              </thingDefs>
            </filter>
            <count>150</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>ComponentSpacer</li>
              </thingDefs>
            </filter>
            <count>1</count>
          </li>
          <li>
            <filter>
              <thingDefs>
                <li>SubcoreHigh</li>
              </thingDefs>
            </filter>
            <count>1</count>
          </li>
        </ingredients>
        <fixedIngredientFilter>
          <thingDefs>
            <li>Corpse_Mech_Apocriton</li>
            <li>Corpse_Mech_Centurion</li>
            <li>Corpse_Mech_Diabolus</li>
            <li>Corpse_Mech_Warqueen</li>
          </thingDefs>
        </fixedIngredientFilter>
        <researchPrerequisite>UltraMechtech</researchPrerequisite>
      </RecipeDef>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="LargeMechGestator"]/recipes</xpath>
    <value>
      <li>ResurrectHostileMediumMech</li>
      <li>ResurrectHostileAdvancedMech</li>
      <li>ResurrectHostileHeavyMech</li>
      <li>ResurrectHostileUltraHeavyMech</li>
    </value>
  </Operation>

</Patch>